{
  "version": 2,
  "builds": [
    {
      "src": "api/*.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/config",
      "dest": "/api/config.mjs"
    },
    {
      "src": "/api/products",
      "dest": "/api/products.mjs"
    },
    {
      "src": "/api/orders",
      "dest": "/api/orders.mjs"
    },
    {
      "src": "/api/order-diagnostic",
      "dest": "/api/order-diagnostic.mjs"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/styles.css",
      "dest": "/public/styles.css"
    },
    {
      "src": "/app.js",
      "dest": "/public/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
